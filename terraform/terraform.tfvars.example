location_primary = "koreacentral"
location_dr      = "japaneast"
prefix           = "asrtest01"
admin_username   = "azureuser"

# Replace with your actual SSH public key
admin_ssh_public_key = "ssh-rsa AAAA..."

# If Standard_D2s_v3 is unavailable, try Standard_D2as_v5 or Standard_B2ms.
vm_size = "Standard_D2s_v3"

# For lab testing, set your public IP CIDR, for example "203.0.113.10/32".
# To check: curl -s ifconfig.me
allowed_admin_cidr = "0.0.0.0/0"

# Japan DR endpoint after ASR failover. Initial value is disabled in Traffic Manager.
dr_endpoint_fqdn = "dr-placeholder.example.com"

# Do not commit real password. Use Key Vault or environment variable in production.
mysql_admin_user     = "mysqladmin"
mysql_admin_password = "ChangeMe_Use_KeyVault_123!"
